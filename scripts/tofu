#!/usr/bin/env bash
# B2 S3 state backend credentials (issue #41), fetched from OpenBao at
# invocation time so direnv loads don't block on network calls.
set -euo pipefail

self=$(realpath "$0")
real=""
while read -r p; do
  if [ "$(realpath "$p")" != "$self" ]; then
    real="$p"
    break
  fi
done < <(which -a tofu)

AWS_ACCESS_KEY_ID=$(bao kv get -field=key_id secret/nixos/backblaze)
AWS_SECRET_ACCESS_KEY=$(bao kv get -field=application_key secret/nixos/backblaze)
export AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY

exec "$real" "$@"
