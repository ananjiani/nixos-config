{% if inventory_hostname == nut_master_host %}
# Master: monitors UPS driver locally
MONITOR {{ nut_ups_name }}@localhost 1 {{ nut_monitor_user }} {{ nut_monitor_password }} master
{% else %}
# Slave: monitors UPS via network from the master host
MONITOR {{ nut_ups_name }}@{{ hostvars[nut_master_host]['ansible_host'] }} 1 {{ nut_slave_user }} {{ nut_monitor_password }} slave
{% endif %}

# Gracefully shut down VMs before powering off the host
SHUTDOWNCMD "/usr/local/bin/nut-shutdown-vms"

# Seconds between LOWBATT and running SHUTDOWNCMD
FINALDELAY {{ nut_finaldelay }}

# Poll interval (seconds)
POLLFREQ 5
POLLFREQALERT 5

# How long to wait before declaring UPS dead (seconds)
DEADTIME 15

# Where to send notifications
NOTIFYCMD /usr/sbin/upssched
NOTIFYFLAG ONLINE SYSLOG
NOTIFYFLAG ONBATT SYSLOG
NOTIFYFLAG LOWBATT SYSLOG
NOTIFYFLAG FSD SYSLOG
NOTIFYFLAG SHUTDOWN SYSLOG
